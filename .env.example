# Copy this file to .env and fill in your keys. Never commit .env.

# Firebase (from Firebase Console → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Spoonacular (from https://spoonacular.com/food-api/console)
EXPO_PUBLIC_SPOONACULAR_API_KEY=
